{
    "extends": "./tsconfig.hug.json",
    "compileOnSave": false,
    "compilerOptions": {
        "rootDir": ".",
        "paths": {
            "@hug/ngx-g11n": [
                "./projects/lib/new"
            ],
            "@hug/ngx-g11n/*": [
                "./projects/lib/*"
            ]
        },
        "composite": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "ES2022",
        "module": "preserve"
    },
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": true,
        "strictInputAccessModifiers": true,
        "strictTemplates": true
    },
    "files": [
        "eslint.config.ts"
    ],
    "references": [
        {
            "path": "./projects/demo-app/tsconfig.app.json"
        },
        {
            "path": "./projects/lib"
        }
    ]
}
