{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "../../out-tsc/lib",
        "declaration": true,
        "declarationMap": true,
        "types": [
            "vitest/globals"
        ]
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "builders/*",
        "schematics/*"
    ],
    "angularCompilerOptions": {
        "extendedDiagnostics": {
            "checks": {
                "nullishCoalescingNotNullable": "suppress",
                "optionalChainNotNullable": "suppress"
            }
        }
    }
}
