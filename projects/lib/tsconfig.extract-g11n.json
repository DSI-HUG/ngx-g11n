
{
	"extends": "../../tsconfig.hug.json",
	"compilerOptions": {
		"baseUrl": ".",
        "rootDir": "builders",
        "outDir": "../../dist/ngx-g11n/builders",
        "module": "commonjs",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "dom"
        ],
        "moduleResolution": "node",
        "declaration": true,
        "declarationMap": false,
        "noEmitOnError": true,
        "skipDefaultLibCheck": true,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "types": [
            "jasmine",
            "node"
        ]
	},
	"include": ["builders/**/*.ts"]
}
